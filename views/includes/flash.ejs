<%if(successMsg && successMsg.length){%>
<div class="alert alert-success mt-3 offset-1 position-relative" role="alert">
    <%=successMsg%>
    <button type="button" class="btn-close position-absolute end-0" data-bs-dismiss="alert" aria-label="Close"></button>
</div>
<%}%>
<%if(errorMsg && errorMsg.length){%>
    <div class="alert alert-danger mt-3 offset-1 position-relative" role="alert">
        <%=errorMsg%>
        <button type="button" class="btn-close position-absolute end-0" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
<%}%>