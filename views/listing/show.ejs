<%-layout("layouts/boilerplate")%>
<h1 class="mt-3 mb-4 offset-2"><%=listing.title%></h1>
<div class="container">
    <div class="card bg-transparent col-10">
        <img src="<%=listing.image.url%>" style="height:400px; width:600px;" class="card-img-top offset-3" alt="image">
        <div class="card-body mb-3">
            <p class="card-text offset-2 mt-4">
                <b>Owned by:</b> @<%=listing.owner.username%><br><br>
                <b>Description:</b> <%=listing.description%><br><br>
                <b>Maximum attendees:</b> <%=listing.capacity%> people<br><br>
                <b>Location:</b> <%=listing.location%><br><br>
                <b>Country:</b> <%=listing.country%>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
                <b>Coordinates:</b> <%=listing.coordinates%><br><br>
                <b>Price:</b> &#8377;<%=listing.price.toLocaleString("en-IN")%> / day
            </p>
            <%if(currUser && currUser._id.equals(listing.owner._id)){%>
            <div class="btns flex">
                <a href="/listings/<%=listing._id%>/edit" type="button" class="btn blue white offset-2 col-1 mt-2 mb-1">Edit</a>
                <form action="/listings/<%=listing._id%>?_method=DELETE" method="POST" class="rel">
                    <button class="btn red white offset-3">Delete</button>
                </form>
            </div>
            <%}else{%>
                <a href="/listings/<%=listing._id%>/booking" type="button" class="btn blue white offset-2 mt-2 mb-1">Book Listing</a>
            <%}%>
        </div>
    </div>
    <hr><br>
    <%if(currUser){%>
    <h3 class="offset-2">Leave a Review</h3>
    <form action="/listings/<%=listing._id%>/reviews" method="POST" class="mt-4 mb-4 col-6 offset-2">
        <label for="rate" class="form-label mb-2">Rating</label>
        <fieldset class="starability-grow">
            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
            <input type="radio" id="first-rate1" name="review[rating]" value="1" />
            <label for="first-rate1" title="Terrible">1 star</label>
            <input type="radio" id="first-rate2" name="review[rating]" value="2" />
            <label for="first-rate2" title="Not good">2 stars</label>
            <input type="radio" id="first-rate3" name="review[rating]" value="3" />
            <label for="first-rate3" title="Average">3 stars</label>
            <input type="radio" id="first-rate4" name="review[rating]" value="4" />
            <label for="first-rate4" title="Very good">4 stars</label>
            <input type="radio" id="first-rate5" name="review[rating]" value="5" />
            <label for="first-rate5" title="Amazing">5 stars</label>
          </fieldset>
        <label for="com" class="form-label mb-4">Comment</label>
        <textarea name="review[comment]" id="com" class="form-control mb-4"></textarea>
        <button class="btn blue white col-2 mb-4">Submit</button>
    </form>
    <hr>
    <%}%>
    <%if(listing.reviews.length>0){%>
    <div class="row offset-2">
        <h3 class="mt-2 mb-3">All Reviews</h3>
        <%for(let review of listing.reviews){%>
        <div class="card col-5 mt-4 mb-4 ms-4">
            <div class="card-body">
                <h5 class="card-heading"><b>@<%=review.author.username%></b></h5>
                <p class="starability-result card-text" data-rating="<%=review.rating%>"></p>                
                <p class="card-text"><%=review.comment%></p>
                <%if(currUser && review.author._id.equals(currUser._id)){%>
                <form action="/listings/<%=listing._id%>/reviews/<%=review._id%>?_method=DELETE" method="POST" >
                    <button class="btn red white">Delete</button>
                </form>
                <%}%>
            </div>
        </div>
        <%}%>
    </div>
    <hr>
    <%}%>
</div>
<div class="row mt-4 mb-4 offset-2">
    <h3 class="mb-4">Where you'll be</h3>
    <div id="map"></div>
    <script>
        const maptoken = "<%=process.env.MAP_TOKEN%>";
        const jString= '<%-JSON.stringify(listing.coordinates)%>';
        const coordinates=JSON.parse(jString);
        const map = new maplibregl.Map({
        container: 'map', // container id
        style:
            `https://api.maptiler.com/maps/streets/style.json?key=${maptoken}`,
        center:coordinates, // starting position[long,lat]
        zoom: 9 // starting zoom
    });
    const marker = new maplibregl.Marker({color:"red"})
    .setLngLat(coordinates)
    .addTo(map);  
    </script>
</div>