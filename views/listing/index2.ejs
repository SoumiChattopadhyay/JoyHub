<%-layout('/layouts/boilerplate.ejs')%>
<%-include("../includes/navbar2.ejs")%>
<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 ms-3"><!--Class row makes dies a horizontal container for everything that comes after and when we mention row calls 3 it means that in one row there will be three columns and whatever comes next is also wrapped up in the form of three columns in one row -->
    <% for(let list of listings){%>
    <a href="/listings/<%=list._id%>" class="list-link">
        <div class="card mt-3 mb-3 bg-transparent" style="width: 18rem;">
            <img src="<%=list.image.url%>" class="card-img-top" alt="img">
            <div class="card-img-overlay"></div><!-- The card-img-overlay is an empty <div>. It is intended to act as a visual layer above the image. The CSS rule changes the overlay's opacity to 0.2, making it semi-transparent.The background-color: white; adds a white overlay over the image.If no background-color is set, the overlay's content will only dim due to the opacity. The card-img-overlay class in Bootstrap is styled to cover the entire card area, aligning it with the dimensions of its parent card. -->
            <div class="card-body">
                <p class="card-text"><b><%=list.title%></b><br><b>Max Attendees:</b> <%=list.capacity%> people <br>
                <span><b>Price:</b> &#8377;<%=list.price.toLocaleString("en-IN")%> / day</span>&nbsp;&nbsp;&nbsp;<i class="tax-info"><b>+15% GST</b></i></p>
            </div>
        </div>
    </a>
    <%}%>
</div>

